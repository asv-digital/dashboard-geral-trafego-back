# ──────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
AGENT_RUN_INTERVAL_MINUTES=240
AGENT_STARTUP_DELAY_SECONDS=30

# ──────────────────────────────────────────────────────────
# Database (Postgres novo — não reutilizar o da v1)
# ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/agente_v2?sslmode=disable

# ──────────────────────────────────────────────────────────
# Auth — sessões assinadas com este segredo
# Gerar com: openssl rand -hex 32
# ──────────────────────────────────────────────────────────
SESSION_SECRET=troque_por_um_segredo_de_64_chars
SESSION_COOKIE_NAME=agente_session
SESSION_MAX_AGE_DAYS=30

# ──────────────────────────────────────────────────────────
# Users iniciais (criados pelo seed)
# ──────────────────────────────────────────────────────────
SEED_OWNER_EMAIL=bravy@bravy.com.br
SEED_OWNER_PASSWORD=troque_esta_senha
SEED_CEO_EMAIL=ceo@bravy.com.br
SEED_CEO_PASSWORD=troque_esta_senha
SEED_COO_EMAIL=coo@bravy.com.br
SEED_COO_PASSWORD=troque_esta_senha

# ──────────────────────────────────────────────────────────
# Meta Graph API (mesma conta da v1 — act_302460482454804)
# ──────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_TOKEN_CREATED_AT=
META_AD_ACCOUNT_ID=act_302460482454804
META_APP_ID=
META_APP_SECRET=
META_PIXEL_ID=1611716643522619
META_PAGE_ID=110354042077811
META_INSTAGRAM_ACTOR_ID=
META_AUDIENCE_BUYERS_ID=
META_AUDIENCE_WARM_ID=
META_AUDIENCE_WARM_NAME=Visitantes 30d
META_GRAPH_VERSION=v19.0

# ──────────────────────────────────────────────────────────
# Kirvano webhook
# ──────────────────────────────────────────────────────────
KIRVANO_WEBHOOK_TOKEN=

# ──────────────────────────────────────────────────────────
# Claude / Anthropic (comment analyzer, copy generation, briefings)
# ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────
# Storage R2 / S3-compat (criativos)
# Vazio => fallback storage local em LOCAL_UPLOADS_DIR.
# ──────────────────────────────────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=agente-criativos
R2_PUBLIC_URL=
LOCAL_UPLOADS_DIR=var/uploads
# URL pública que serve /uploads/* quando storage=local (prod)
BACKEND_PUBLIC_URL=

# ──────────────────────────────────────────────────────────
# WhatsApp notifier
# zappfy: usa WHATSAPP_TOKEN/INSTANCE/PHONE
# evolution: precisa também de EVOLUTION_URL
# ──────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=zappfy
WHATSAPP_INSTANCE_ID=
WHATSAPP_TOKEN=
WHATSAPP_PHONE=
EVOLUTION_URL=
